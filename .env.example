NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token
# Base Mapbox style (light-v11 recommended for pastel tinting in lib/mapTheme.ts)
NEXT_PUBLIC_MAPBOX_STYLE=mapbox://styles/mapbox/light-v11

# Optional map color defaults (deploy-wide). Users can also tune via Map colors in the app menu.
# NEXT_PUBLIC_MAP_WATER=#A8CCE8
# NEXT_PUBLIC_MAP_PARK=#D4E8D4
# NEXT_PUBLIC_MAP_DISCOVERY_FILL=#93C5FD
# NEXT_PUBLIC_MAP_DISCOVERY_OUTLINE=#5B9BD5
# NEXT_PUBLIC_MAP_USER_PIN=#5BA3B8
# NEXT_PUBLIC_MAP_TINT_STRENGTH=0.45
# NEXT_PUBLIC_MAP_FOG=true
